<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>{{ blog.title }}</h1></div>
    {%- paginate blog.articles by 9 -%}
      <div class="product-grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="article-card">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 500 }}" alt="{{ article.title | escape }}" width="500" height="281" loading="lazy">
            {%- endif -%}
            <div class="article-card__body">
              <div class="article-card__meta">{{ article.published_at | date: '%B %d, %Y' }}</div>
              <h3 style="font-size:16px;margin-bottom:8px;">{{ article.title }}</h3>
              <p style="font-size:13px;color:#666;">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
            </div>
          </a>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="is-current">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>
