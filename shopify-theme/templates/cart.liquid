<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>Shopping Cart</h1></div>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <table class="cart-table">
          <thead>
            <tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr>
                <td>
                  <div class="cart-item">
                    {%- if item.image -%}<a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title | escape }}" width="74" height="74" loading="lazy"></a>{%- endif -%}
                    <div>
                      <a href="{{ item.url }}" style="font-weight:500;">{{ item.product.title }}</a>
                      {%- unless item.variant.title contains 'Default' -%}<div style="font-size:12px;color:var(--color-muted);">{{ item.variant.title }}</div>{%- endunless -%}
                    </div>
                  </div>
                </td>
                <td>{{ item.original_price | money }}</td>
                <td>
                  <div class="product-form__qty">
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:56px;">
                  </div>
                </td>
                <td>{{ item.original_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div class="cart-footer">
          <button type="submit" name="update" class="btn btn--outline">Update</button>
          <span class="cart-footer__total">Total: {{ cart.total_price | money }}</span>
          <button type="submit" name="checkout" class="btn">Checkout</button>
        </div>
      </form>
    {%- else -%}
      <div class="cart-empty">
        <p style="margin-bottom:20px;color:var(--color-muted);">Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn">Continue shopping</a>
      </div>
    {%- endif -%}
  </div>
</div>
