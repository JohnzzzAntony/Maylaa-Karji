<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>Login</h1></div>
    <div class="form">
      {%- form 'customer_login' -%}
        {%- if form.errors -%}<p class="form__note form__note--error">{{ form.errors | default_errors }}</p>{%- endif -%}
        <div class="form__field">
          <label for="customer_email">Email</label>
          <input type="email" name="customer[email]" id="customer_email" required>
        </div>
        <div class="form__field">
          <label for="customer_password">Password</label>
          <input type="password" name="customer[password]" id="customer_password" required>
        </div>
        <div class="form__actions">
          <button type="submit" class="btn" style="width:100%;">Sign in</button>
        </div>
        <div class="form__links">
          <a href="#" onclick="document.getElementById('RecoverForm').style.display='block';return false;">Forgot your password?</a>
          &nbsp;·&nbsp;
          <a href="{{ routes.account_register_url }}">Create account</a>
        </div>
      {%- endform -%}

      <div id="RecoverForm" style="display:none;margin-top:24px;">
        {%- form 'recover_customer_password' -%}
          <h3 style="font-size:16px;margin-bottom:12px;">Reset password</h3>
          {%- if form.posted_successfully? -%}<p class="form__note form__note--success">We've sent you an email with a link to reset your password.</p>{%- endif -%}
          <div class="form__field">
            <label for="recover_email">Email</label>
            <input type="email" name="email" id="recover_email" required>
          </div>
          <button type="submit" class="btn" style="width:100%;">Send reset link</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>
