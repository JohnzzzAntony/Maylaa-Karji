<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>Reset Password</h1></div>
    <div class="form">
      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}<p class="form__note form__note--error">{{ form.errors | default_errors }}</p>{%- endif -%}
        <div class="form__field">
          <label for="pw">New password</label>
          <input type="password" name="customer[password]" id="pw" required>
        </div>
        <div class="form__field">
          <label for="pw_confirm">Confirm password</label>
          <input type="password" name="customer[password_confirmation]" id="pw_confirm" required>
        </div>
        <button type="submit" class="btn" style="width:100%;">Reset password</button>
      {%- endform -%}
    </div>
  </div>
</div>
