<div class="section">
  <div class="page-width">
    <div class="section-header">
      <h1 class="section-header__title">My Account</h1>
      <a href="{{ routes.account_logout_url }}" class="link-view-all">Log out</a>
    </div>

    <p style="margin-bottom:20px;">Welcome back, {{ customer.first_name | default: customer.email }}. <a href="{{ routes.account_addresses_url }}" style="color:var(--color-accent);">Manage addresses</a></p>

    <h3 style="margin-bottom:16px;">Order history</h3>
    {%- if customer.orders.size > 0 -%}
      <table class="cart-table">
        <thead><tr><th>Order</th><th>Date</th><th>Payment</th><th>Fulfillment</th><th>Total</th></tr></thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}" style="color:var(--color-accent);">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_net_amount | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p style="color:var(--color-muted);">You haven't placed any orders yet.</p>
    {%- endif -%}
  </div>
</div>
