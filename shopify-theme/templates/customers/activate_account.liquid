<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>Activate Account</h1><p style="color:var(--color-muted);">Create your password to activate your account.</p></div>
    <div class="form">
      {%- form 'activate_customer_password' -%}
        {%- if form.errors -%}<p class="form__note form__note--error">{{ form.errors | default_errors }}</p>{%- endif -%}
        <div class="form__field">
          <label for="act_pw">Password</label>
          <input type="password" name="customer[password]" id="act_pw" required>
        </div>
        <div class="form__field">
          <label for="act_pw_confirm">Confirm password</label>
          <input type="password" name="customer[password_confirmation]" id="act_pw_confirm" required>
        </div>
        <div class="form__actions" style="display:flex;gap:12px;">
          <button type="submit" name="commit" class="btn">Activate account</button>
          <button type="submit" name="decline" class="btn btn--outline">Decline invitation</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>
