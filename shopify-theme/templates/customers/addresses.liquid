<div class="section">
  <div class="page-width">
    <div class="section-header">
      <h1 class="section-header__title">My Addresses</h1>
      <a href="{{ routes.account_url }}" class="link-view-all">Back to account</a>
    </div>

    <div class="form" style="max-width:520px;margin:0 0 32px;">
      <h3 style="margin-bottom:14px;">Add a new address</h3>
      {%- form 'customer_address', customer.new_address -%}
        <div class="form__field"><label>First name</label><input type="text" name="address[first_name]"></div>
        <div class="form__field"><label>Last name</label><input type="text" name="address[last_name]"></div>
        <div class="form__field"><label>Address</label><input type="text" name="address[address1]"></div>
        <div class="form__field"><label>City</label><input type="text" name="address[city]"></div>
        <div class="form__field"><label>Country</label><input type="text" name="address[country]"></div>
        <div class="form__field"><label>Phone</label><input type="tel" name="address[phone]"></div>
        <button type="submit" class="btn">Save address</button>
      {%- endform -%}
    </div>

    {%- for address in customer.addresses -%}
      <div style="border:1px solid var(--color-border);border-radius:8px;padding:18px;margin-bottom:14px;">
        {{ address | format_address }}
        {%- if address == customer.default_address -%}<div style="font-size:12px;color:var(--color-accent);margin-top:6px;">Default address</div>{%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
