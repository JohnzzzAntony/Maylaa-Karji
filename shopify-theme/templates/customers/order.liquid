<div class="section">
  <div class="page-width">
    <div class="page-heading"><h1>Order {{ order.name }}</h1><p style="color:var(--color-muted);">Placed on {{ order.created_at | date: '%B %d, %Y' }}</p></div>

    <table class="cart-table">
      <thead><tr><th>Product</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
      <tbody>
        {%- for line in order.line_items -%}
          <tr>
            <td>
              <div class="cart-item">
                {%- if line.image -%}<img src="{{ line.image | image_url: width: 150 }}" alt="{{ line.title | escape }}" width="74" height="74" loading="lazy">{%- endif -%}
                <div>{{ line.title }}</div>
              </div>
            </td>
            <td>{{ line.price | money }}</td>
            <td>{{ line.quantity }}</td>
            <td>{{ line.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    <div class="cart-footer">
      <span class="cart-footer__total">Total: {{ order.total_net_amount | money }}</span>
    </div>

    <p style="margin-top:20px;"><a href="{{ routes.account_url }}" style="color:var(--color-accent);">&larr; Back to account</a></p>
  </div>
</div>
