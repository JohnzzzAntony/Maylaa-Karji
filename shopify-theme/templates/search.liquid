<div class="section">
  <div class="page-width">
    <div class="page-heading">
      <h1>Search</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:520px;margin:18px auto 0;">
        <div class="site-header__search" style="max-width:none;">
          <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
          <button type="submit" aria-label="{{ 'general.search.submit' | t }}">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        <p style="text-align:center;color:var(--color-muted);margin-bottom:24px;">{{ search.results_count }} result(s) for "{{ search.terms | escape }}"</p>
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a href="{{ item.url }}" class="article-card"><div class="article-card__body"><h3 style="font-size:15px;">{{ item.title }}</h3></div></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="text-align:center;color:var(--color-muted);">No results found for "{{ search.terms | escape }}".</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% render 'quick-view-modal' %}
