<div class="section">
  <div class="page-width">
    <div class="page-heading">
      <nav class="breadcrumb" style="text-align:center;"><a href="{{ routes.root_url }}">Home</a> / {{ collection.title }}</nav>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<div class="rte" style="max-width:640px;margin:12px auto 0;color:#666;">{{ collection.description }}</div>{%- endif -%}
    </div>

    {%- paginate collection.products by 24 -%}
      {%- if collection.products.size > 0 -%}
        <div class="product-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="is-current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <p style="text-align:center;color:var(--color-muted);">No products found.</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% render 'quick-view-modal' %}
