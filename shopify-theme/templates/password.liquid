{% layout 'password' %}
<div class="password-page">
  <div class="password-page__logo">
    {%- if settings.logo -%}
      <img src="{{ settings.logo | image_url: width: 400 }}" width="{{ settings.logo_width }}" alt="{{ shop.name }}" style="width:{{ settings.logo_width }}px;">
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </div>

  <h1 style="margin-bottom:10px;">Opening soon</h1>
  <p style="color:var(--color-muted);max-width:420px;margin-bottom:24px;">{{ page_description | default: 'Be the first to know when we launch.' }}</p>

  {%- form 'storefront_password', class: 'newsletter__form' -%}
    {%- if form.errors -%}<p class="form__note form__note--error">{{ form.errors | default_errors }}</p>{%- endif -%}
    <input type="password" name="password" placeholder="Enter store password" aria-label="Password">
    <button type="submit">Enter</button>
  {%- endform -%}

  <div style="margin-top:28px;">
    <h3 style="font-size:15px;margin-bottom:10px;">Notify me when available</h3>
    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="prospect, password page">
      <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.email' | t }}" aria-label="Email" required>
      <button type="submit" name="commit">{{ 'general.newsletter.submit' | t }}</button>
      {%- if form.posted_successfully? -%}<p class="form__note form__note--success" style="width:100%;">{{ 'general.newsletter.success' | t }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</div>
