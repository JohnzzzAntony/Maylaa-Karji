{%- comment -%} Shared quick view modal, rendered once per page {%- endcomment -%}
<div class="quickview-modal" data-quickview-modal aria-hidden="true" role="dialog" aria-modal="true">
  <div class="quickview-modal__dialog" data-quickview-content>
    <button type="button" class="quickview-modal__close" data-quickview-close aria-label="{{ 'accessibility.close' | t }}">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <div class="quickview-modal__media">
      <img data-qv-image src="" alt="" loading="lazy">
    </div>
    <div class="quickview-modal__body">
      <h3 class="quickview-modal__title" data-qv-title></h3>
      <div class="quickview-modal__price" data-qv-price></div>
      <div class="quickview-modal__desc" data-qv-desc></div>
      <a href="#" class="btn" data-qv-link>{{ 'products.product.shop_now' | t }}</a>
    </div>
  </div>
</div>
