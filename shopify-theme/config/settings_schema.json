[
  {
    "name": "theme_info",
    "theme_name": "Karji Premium",
    "theme_version": "1.0.0",
    "theme_author": "Karji",
    "theme_documentation_url": "https://shopify.dev",
    "theme_support_url": "https://shopify.dev"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent / Primary",
        "default": "#b8895a"
      },
      {
        "type": "color",
        "id": "color_accent_dark",
        "label": "Accent dark (hover)",
        "default": "#96693e"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#1f1f1f"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_dark_section",
        "label": "Dark sections (footer, service bar)",
        "default": "#26313d"
      },
      {
        "type": "color",
        "id": "color_hero_bg",
        "label": "Hero fallback background",
        "default": "#f6dcd8"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "label": "Heading font",
        "default": "assistant_n6"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1280
      },
      {
        "type": "range",
        "id": "section_spacing",
        "min": 20,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Spacing between sections",
        "default": 56
      }
    ]
  },
  {
    "name": "Product card",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_wishlist",
        "label": "Show wishlist icon",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_quick_view",
        "label": "Show quick view button",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_sale_badge",
        "label": "Show sale badge",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_second_image",
        "label": "Show second image on hover",
        "default": true
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 120
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable sticky header",
        "default": true
      }
    ]
  },
  {
    "name": "Floating WhatsApp",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_whatsapp",
        "label": "Enable WhatsApp button",
        "default": true
      },
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "WhatsApp number (with country code, no +)",
        "default": "971500000000"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon (32x32 png)"
      }
    ]
  }
]
