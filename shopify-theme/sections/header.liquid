{%- liquid
  assign menu = section.settings.menu
-%}

<div class="header-wrapper{% if settings.sticky_header %} is-sticky{% endif %}">
  {%- if section.settings.show_announcement -%}
    <div class="announcement-bar">
      <div class="page-width announcement-bar__inner">
        <div class="announcement-bar__message">{{ section.settings.announcement_text }}</div>
        <div class="announcement-bar__utility">
          {%- if section.settings.utility_link_1_text != blank -%}
            <a href="{{ section.settings.utility_link_1_url }}">{{ section.settings.utility_link_1_text }}</a>
          {%- endif -%}
          {%- if section.settings.utility_link_2_text != blank -%}
            <a href="{{ section.settings.utility_link_2_url }}">{{ section.settings.utility_link_2_text }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <header class="site-header">
    <div class="page-width site-header__inner">
      <a href="{{ routes.root_url }}" class="site-header__logo">
        {%- if settings.logo -%}
          <img
            src="{{ settings.logo | image_url: width: 400 }}"
            width="{{ settings.logo_width }}"
            alt="{{ shop.name }}"
            style="width: {{ settings.logo_width }}px;"
          >
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>

      <form action="{{ routes.search_url }}" method="get" class="site-header__search" role="search">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.submit' | t }}">
        <button type="submit" aria-label="{{ 'general.search.submit' | t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
      </form>

      <div class="site-header__icons">
        <a href="{{ routes.account_url }}" class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          <span>{{ 'accessibility.account' | t }}</span>
        </a>
        <a href="{{ section.settings.wishlist_url | default: '#' }}" class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
          <span>{{ 'accessibility.wishlist' | t }}</span>
          <span class="header-icon__count" data-wishlist-count style="display:none">0</span>
        </a>
        <a href="{{ routes.cart_url }}" class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span>{{ 'accessibility.cart' | t }}</span>
          <span class="header-icon__count">{{ cart.item_count }}</span>
        </a>
        <button type="button" class="header-icon header-menu-toggle" data-drawer-toggle aria-label="{{ 'accessibility.menu' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
      </div>
    </div>

    {%- if menu != blank -%}
      <nav class="site-nav">
        <ul class="site-nav__list">
          {%- for link in linklists[menu].links -%}
            <li class="site-nav__item">
              <a href="{{ link.url }}">{{ link.title }}</a>
              {%- if link.links != blank -%}
                <ul class="site-nav__dropdown">
                  {%- for child in link.links -%}
                    <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}
  </header>
</div>

{%- comment -%} Mobile drawer {%- endcomment -%}
<div class="mobile-drawer__overlay" data-drawer-overlay></div>
<aside class="mobile-drawer" data-mobile-drawer>
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <span class="site-header__logo" style="font-size:20px;">{{ shop.name }}</span>
    <button type="button" data-drawer-close aria-label="{{ 'accessibility.close' | t }}">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <form action="{{ routes.search_url }}" method="get" class="site-header__search" style="display:block;margin-top:16px;max-width:none;">
    <input type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}">
  </form>
  {%- if menu != blank -%}
    <ul class="mobile-drawer__list">
      {%- for link in linklists[menu].links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</aside>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free Shipping on orders over 100 AED"
    },
    {
      "type": "text",
      "id": "utility_link_1_text",
      "label": "Utility link 1 text",
      "default": "En"
    },
    {
      "type": "url",
      "id": "utility_link_1_url",
      "label": "Utility link 1 URL"
    },
    {
      "type": "text",
      "id": "utility_link_2_text",
      "label": "Utility link 2 text",
      "default": "AED"
    },
    {
      "type": "url",
      "id": "utility_link_2_url",
      "label": "Utility link 2 URL"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist page URL"
    }
  ]
}
{% endschema %}
