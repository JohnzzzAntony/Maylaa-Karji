<div class="section">
  <div class="page-width">
    {%- assign feature = section.settings.banner_image -%}
    <a href="{{ section.settings.banner_url | default: '#' }}" class="promo-banner">
      {%- if feature != blank -%}
        <img
          src="{{ feature | image_url: width: 1600 }}"
          srcset="{{ feature | image_url: width: 800 }} 800w, {{ feature | image_url: width: 1600 }} 1600w"
          sizes="100vw"
          alt="{{ section.settings.banner_title | escape }}"
          width="1600" height="420"
          loading="lazy"
        >
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: '' }}
      {%- endif -%}
      {%- if section.settings.banner_title != blank or section.settings.banner_subtitle != blank -%}
        <div class="promo-banner__content promo-banner__content--{{ section.settings.text_position }}" style="color: {{ section.settings.text_color }};">
          {%- if section.settings.banner_subtitle != blank -%}<div class="promo-banner__subtitle">{{ section.settings.banner_subtitle }}</div>{%- endif -%}
          {%- if section.settings.banner_title != blank -%}<div class="promo-banner__title">{{ section.settings.banner_title }}</div>{%- endif -%}
        </div>
      {%- endif -%}
    </a>

    {%- if section.blocks.size > 0 -%}
      <div class="promo-mini-grid">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="promo-mini" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.alt | escape }}"
                width="600" height="338"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: '' }}
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Promotional banner",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Main banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Title",
      "default": "PARFUMS"
    },
    {
      "type": "url",
      "id": "banner_url",
      "label": "Link"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "mini",
      "name": "Small image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotional banner",
      "blocks": [
        { "type": "mini" },
        { "type": "mini" },
        { "type": "mini" }
      ]
    }
  ]
}
{% endschema %}
