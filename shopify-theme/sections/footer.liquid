<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__top">
      {%- for block in section.blocks -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {%- case block.type -%}

            {%- when 'menu' -%}
              {%- if block.settings.title != blank -%}<div class="footer-block__title">{{ block.settings.title }}</div>{%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-block__list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'contact' -%}
              {%- if block.settings.title != blank -%}<div class="footer-block__title">{{ block.settings.title }}</div>{%- endif -%}
              <ul class="footer-contact">
                {%- if block.settings.address != blank -%}
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-7-6-7-11a7 7 0 0 1 14 0c0 5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
                    <span>{{ block.settings.address }}</span>
                  </li>
                {%- endif -%}
                {%- if block.settings.email != blank -%}
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                    <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                  </li>
                {%- endif -%}
                {%- if block.settings.phone != blank -%}
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2z"/></svg>
                    <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a>
                  </li>
                {%- endif -%}
              </ul>

            {%- when 'social' -%}
              {%- if block.settings.title != blank -%}<div class="footer-block__title">{{ block.settings.title }}</div>{%- endif -%}
              <div class="footer-social">
                {%- if block.settings.facebook != blank -%}<a href="{{ block.settings.facebook }}" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1-3 3v2H9v3h2v6h3v-6h2.3l.7-3H14V9z"/></svg></a>{%- endif -%}
                {%- if block.settings.instagram != blank -%}<a href="{{ block.settings.instagram }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17" cy="7" r="1" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
                {%- if block.settings.youtube != blank -%}<a href="{{ block.settings.youtube }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 8s-.2-1.4-.8-2c-.8-.8-1.7-.8-2.1-.9C16.3 5 12 5 12 5s-4.3 0-7.1.2c-.4 0-1.3 0-2.1.9C2.2 6.6 2 8 2 8s-.2 1.6-.2 3.3v1.4C1.8 14.4 2 16 2 16s.2 1.4.8 2c.8.8 1.8.8 2.3.9C6.7 19 12 19 12 19s4.3 0 7.1-.2c.4 0 1.3 0 2.1-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.4C22.2 9.6 22 8 22 8zM10 15V9l5 3z"/></svg></a>{%- endif -%}
                {%- if block.settings.tiktok != blank -%}<a href="{{ block.settings.tiktok }}" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 3c.3 2 1.6 3.6 3.5 4v3c-1.3 0-2.5-.4-3.5-1v6.5A5.5 5.5 0 1 1 10.5 10v3a2.5 2.5 0 1 0 2.5 2.5V3z"/></svg></a>{%- endif -%}
                {%- if block.settings.whatsapp != blank -%}<a href="{{ block.settings.whatsapp }}" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2zm5 14c-.2.6-1.2 1.2-1.7 1.2-.4 0-1 .1-3.3-.9-2.8-1.2-4.5-4-4.6-4.2-.1-.2-1-1.4-1-2.6s.6-1.8.9-2.1c.2-.2.5-.3.6-.3h.5c.2 0 .4 0 .5.4l.7 1.7c.1.2 0 .4-.1.5l-.3.4c-.1.2-.3.3-.1.6.1.3.6 1.1 1.4 1.7 1 .9 1.7 1.1 2 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.6.8c.2.1.4.2.4.3.1.1.1.6-.1 1z"/></svg></a>{%- endif -%}
              </div>

            {%- when 'payments' -%}
              {%- if block.settings.title != blank -%}<div class="footer-block__title">{{ block.settings.title }}</div>{%- endif -%}
              <div class="footer-payments">
                {%- for i in (1..6) -%}
                  {%- assign key = 'image_' | append: i -%}
                  {%- assign img = block.settings[key] -%}
                  {%- if img != blank -%}
                    <img src="{{ img | image_url: width: 120 }}" alt="Payment method" width="60" height="26" loading="lazy">
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- when 'apps' -%}
              {%- if block.settings.title != blank -%}<div class="footer-block__title">{{ block.settings.title }}</div>{%- endif -%}
              <div class="footer-apps">
                {%- if block.settings.google_play != blank and block.settings.google_play_url != blank -%}
                  <a href="{{ block.settings.google_play_url }}"><img src="{{ block.settings.google_play | image_url: width: 300 }}" alt="Google Play" width="150" height="44" loading="lazy"></a>
                {%- endif -%}
                {%- if block.settings.app_store != blank and block.settings.app_store_url != blank -%}
                  <a href="{{ block.settings.app_store_url }}"><img src="{{ block.settings.app_store | image_url: width: 300 }}" alt="App Store" width="150" height="44" loading="lazy"></a>
                {%- endif -%}
              </div>

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>{{ section.settings.copyright | default: '© 2026 Karji. All rights reserved.' }}</span>
      {%- if section.settings.credit != blank -%}<span>{{ section.settings.credit }}</span>{%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Karji. All rights reserved."
    },
    {
      "type": "text",
      "id": "credit",
      "label": "Credit text",
      "default": "Website Designed by"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Categories" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "contact",
      "name": "Contact column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Contact Us" },
        { "type": "textarea", "id": "address", "label": "Address" },
        { "type": "text", "id": "email", "label": "Email" },
        { "type": "text", "id": "phone", "label": "Phone" }
      ]
    },
    {
      "type": "social",
      "name": "Social column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Social Media" },
        { "type": "url", "id": "facebook", "label": "Facebook" },
        { "type": "url", "id": "instagram", "label": "Instagram" },
        { "type": "url", "id": "youtube", "label": "YouTube" },
        { "type": "url", "id": "tiktok", "label": "TikTok" },
        { "type": "url", "id": "whatsapp", "label": "WhatsApp" }
      ]
    },
    {
      "type": "payments",
      "name": "Payment column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Payment Options" },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "image_picker", "id": "image_4", "label": "Image 4" },
        { "type": "image_picker", "id": "image_5", "label": "Image 5" },
        { "type": "image_picker", "id": "image_6", "label": "Image 6" }
      ]
    },
    {
      "type": "apps",
      "name": "App download column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Download our Apps" },
        { "type": "image_picker", "id": "google_play", "label": "Google Play badge" },
        { "type": "url", "id": "google_play_url", "label": "Google Play URL" },
        { "type": "image_picker", "id": "app_store", "label": "App Store badge" },
        { "type": "url", "id": "app_store_url", "label": "App Store URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" },
        { "type": "contact" },
        { "type": "apps" }
      ]
    }
  ]
}
{% endschema %}
