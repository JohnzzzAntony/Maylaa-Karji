// ScentGrade Luxury Perfume E-Commerce Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  country     String
  description String
  logoColor   String   @default("#B8935A")
  createdAt   DateTime @default(now())
  products    Product[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  image       String
  createdAt   DateTime @default(now())
  products    Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  brandId        String
  categoryId     String
  description    String
  longDescription String
  price          Float
  compareAtPrice Float?
  currency       String   @default("AED")
  size           Int      @default(100)
  sizeUnit       String   @default("ml")
  concentration  String   @default("Eau de Parfum")
  topNotes       String
  heartNotes     String
  baseNotes      String
  images         String   // JSON array of image paths
  rating         Float    @default(4.5)
  reviewCount    Int      @default(0)
  stock          Int      @default(50)
  sku            String   @unique
  badge          String?
  gender         String   @default("Unisex")
  isTrending     Boolean  @default(false)
  isExclusive    Boolean  @default(false)
  isBestSeller   Boolean  @default(false)
  isArtisanal    Boolean  @default(false)
  isFeatured     Boolean  @default(false)
  isNew          Boolean  @default(false)
  // SEO fields
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  createdAt      DateTime @default(now())
  brand          Brand    @relation(fields: [brandId], references: [id])
  category       Category @relation(fields: [categoryId], references: [id])
  reviews        Review[]
  wishlistItems  WishlistItem[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  author    String
  rating    Int
  title     String
  content   String
  verified  Boolean  @default(true)
  location  String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id           String   @id @default(cuid())
  email        String
  customerName String
  items        String   // JSON array
  subtotal     Float
  shipping     Float
  total        Float
  currency     String   @default("AED")
  status       String   @default("pending")
  address      String   // JSON
  userId       String?
  createdAt    DateTime @default(now())
  user         User?    @relation("UserOrders", fields: [userId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ===== Admin modules =====

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  image     String
  link      String   @default("#")
  position  String   @default("hero") // hero | mid | footer
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BogoOffer {
  id            String   @id @default(cuid())
  title         String
  description   String
  buyProductId  String?
  buyQty        Int      @default(1)
  getProductId  String?
  getQty        Int      @default(1)
  discountPct   Int      @default(100)
  isActive      Boolean  @default(true)
  startsAt      DateTime @default(now())
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Advertisement {
  id        String   @id @default(cuid())
  title     String
  image     String
  link      String   @default("#")
  placement String   @default("sidebar") // sidebar | inline | popup
  isActive  Boolean  @default(true)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  code        String   @unique
  type        String   @default("percent") // percent | fixed | shipping
  value       Float    @default(10)
  minSpend    Float    @default(0)
  usageLimit  Int      @default(100)
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime @default(now())
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  isPublished Boolean @default(true)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConfigSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String
  group String @default("general") // general | shipping | payment | tax
  updatedAt DateTime @updatedAt
}

// ===== Auth & Wishlist =====

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("customer")
  createdAt DateTime @default(now())
  wishlist  WishlistItem[]
  orders    Order[]  @relation("UserOrders")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

